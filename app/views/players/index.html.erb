<h1>Players</h1>

<div class="filter-bar">
  <form method="get" action="<%= players_path %>">
    <select name="serie_id" onchange="this.form.submit()">
      <option value="">All Series</option>
      <% @series.each do |serie| %>
        <option value="<%= serie.id %>" <%= "selected" if @selected_serie&.id == serie.id %>><%= serie.name %></option>
      <% end %>
    </select>
  </form>
  <form method="get" action="<%= players_path %>">
    <select name="tournament_id" onchange="this.form.submit()">
      <option value="">All Tournaments</option>
      <% @tournaments.each do |tournament| %>
        <option value="<%= tournament.id %>" <%= "selected" if @selected_tournament&.id == tournament.id %>><%= tournament.name %></option>
      <% end %>
    </select>
  </form>
</div>

<%= link_to "New Player", new_player_path, class: "button" %>

<% if @players.any? %>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @players.each do |player| %>
        <tr>
          <td><%= player.name %></td>
          <td class="actions">
            <%= link_to "Edit", edit_player_path(player) %>
            <%= button_to "Delete", player_path(player), method: :delete, data: { turbo_confirm: "Delete #{player.name}?" }, class: "button-danger" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="empty-state">No players found.</p>
<% end %>
