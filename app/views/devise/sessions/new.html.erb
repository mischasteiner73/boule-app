<div class="auth-card">
  <div class="auth-header">
    <div class="auth-logo">🎯</div>
    <h1>Boule Tournament</h1>
    <p>Sign in to continue</p>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="field">
      <%= f.label :email, "Email" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "your@email.com" %>
    </div>

    <div class="field">
      <%= f.label :password, "Password" %>
      <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="field-inline">
        <%= f.check_box :remember_me %>
        <%= f.label :remember_me %>
      </div>
    <% end %>

    <%= f.submit "Sign in", class: "button button-full" %>
  <% end %>

  <div class="auth-links">
    <%= link_to "Forgot your password?", new_password_path(resource_name) %>
  </div>
</div>
