<div class="auth-card">
  <div class="auth-header">
    <div class="auth-logo">🎯</div>
    <h1>Change password</h1>
  </div>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <%= f.hidden_field :reset_password_token %>

    <div class="field">
      <%= f.label :password, "New password" %>
      <% if @minimum_password_length %>
        <small class="field-hint"><%= @minimum_password_length %> characters minimum</small>
      <% end %>
      <%= f.password_field :password, autofocus: true, autocomplete: "new-password", placeholder: "••••••••" %>
    </div>

    <div class="field">
      <%= f.label :password_confirmation, "Confirm new password" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••" %>
    </div>

    <%= f.submit "Change my password", class: "button button-full" %>
  <% end %>

  <div class="auth-links">
    <%= link_to "Back to sign in", new_session_path(resource_name) %>
  </div>
</div>
