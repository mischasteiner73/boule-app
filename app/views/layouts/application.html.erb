<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Boule Tournament" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav data-controller="nav">
      <div class="nav-brand"><%= link_to "🎯 Boule", root_path %></div>
      <button class="nav-hamburger" data-action="nav#toggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
      <div class="nav-links" data-nav-target="menu">
        <%= link_to "Players", players_path, data: { action: "nav#close" } %>
        <%= link_to "Series", tournament_series_index_path, data: { action: "nav#close" } %>
        <%= link_to "Tournaments", tournaments_path, data: { action: "nav#close" } %>
        <%= link_to "Games", games_path, data: { action: "nav#close" } %>
        <%= link_to "New Game", new_game_path, data: { action: "nav#close" } %>
        <%= link_to "Statistics", statistics_path, data: { action: "nav#close" } %>
        <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "button-nav-signout" %>
      </div>
    </nav>

    <main>
      <% if notice.present? %>
        <div class="flash flash-notice"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="flash flash-alert"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>

