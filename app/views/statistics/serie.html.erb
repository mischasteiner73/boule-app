<h1>Statistics — <%= @serie.name %></h1>

<div class="stats-nav">
  <%= link_to "← Overall Statistics", statistics_path, class: "button-secondary" %>
  <% @series.each do |serie| %>
    <%= link_to serie.name, statistics_tournament_series_path(serie), class: "button-secondary #{'button-secondary-active' if serie == @serie}" %>
  <% end %>
  <% @tournaments.each do |tournament| %>
    <%= link_to tournament.name, statistics_tournament_path(tournament), class: "button-secondary" %>
  <% end %>
</div>

<%= render "statistics" %>
